{
  "name": "ai-savior-browser-extension",
  "version": "0.1.0",
  "description": "Browser extension to automatically save AI conversations from ChatGPT, Claude, Perplexity, and Kimi",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:chrome",
    "dev:chrome": "vite build --watch --mode chrome",
    "dev:brave": "vite build --watch --mode brave",
    "dev:firefox": "vite build --watch --mode firefox",
    "build": "npm run build:chrome",
    "build:all": "npm run build:chrome && npm run build:brave && npm run build:firefox",
    "build:chrome": "tsc && vite build --mode chrome",
    "build:brave": "tsc && vite build --mode brave",
    "build:firefox": "tsc && vite build --mode firefox",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.js",
    "download-favicons": "node scripts/download-favicons.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug"
  },
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "firefox-extension",
    "brave-extension",
    "ai",
    "chatgpt",
    "claude",
    "conversation-saver"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.10.6",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-web-extension": "^4.1.1"
  }
}
